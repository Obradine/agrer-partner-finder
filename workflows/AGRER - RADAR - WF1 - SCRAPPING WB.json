    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $json;\nconst projectId = item.project_id;\n\ntry {\n  const data = await this.helpers.httpRequest({\n    method: 'GET',\n    url: `https://search.worldbank.org/api/v2/projects?format=json&id=${projectId}`,\n    json: true\n  });\n\n  const project = data.projects?.[projectId];\n  if (!project) {\n    return {\n      json: {\n        project_id: projectId,\n        project_name: '',\n        country: '',\n        status: 'not_found',\n        total_amt: '',\n        approval_date: '',\n        closing_date: '',\n        implementing_agency: '',\n        sector_primary: '',\n        sectors_all: '',\n        theme_primary: '',\n        themes_all: '',\n        sub_themes: '',\n        project_url: `https://projects.worldbank.org/en/projects-operations/project-detail/${projectId}`\n      }\n    };\n  }\n\n  // Secteurs\n  const sectors = (project.sector_namecode || []).map(s => s.name).join(' | ');\n  const sectorPrimary = project.sector1?.Name || (project.sector_namecode?.[0]?.name || '');\n\n  // ThÃĻmes niveau 1\n  const themeList = project.theme_list || [];\n  const themesSorted = [...themeList].sort((a, b) => (b.percent || 0) - (a.percent || 0));\n  const themePrimary = themesSorted[0]?.name || '';\n  const themesAll = themesSorted.map(t => `${t.name} (${t.percent}%)`).join(' | ');\n\n  // Sous-thÃĻmes niveau 2 (top 5)\n  const subThemes = [];\n  for (const t of themeList) {\n    for (const t2 of (t.theme2 || [])) {\n      subThemes.push({ name: t2.name, percent: t2.percent || 0 });\n    }\n  }\n  const subThemesSorted = subThemes.sort((a, b) => b.percent - a.percent).slice(0, 5);\n  const subThemesStr = subThemesSorted.map(t => `${t.name} (${t.percent}%)`).join(' | ');\n\n  return {\n    json: {\n      project_id: projectId,\n      project_name: project.project_name || '',\n      country: project.countryshortname || '',\n      status: project.status || '',\n      total_amt: project.totalamt || '',\n      approval_date: project.boardapprovaldate ? project.boardapprovaldate.split('T')[0] : '',\n      closing_date: project.closingdate || '',\n      implementing_agency: project.impagency || '',\n      sector_primary: sectorPrimary,\n      sectors_all: sectors,\n      theme_primary: themePrimary,\n      themes_all: themesAll,\n      sub_themes: subThemesStr,\n      project_url: project.url || `https://projects.worldbank.org/en/projects-operations/project-detail/${projectId}`\n    }\n  };\n\n} catch (error) {\n  return {\n    json: {\n      project_id: projectId,\n      project_name: '',\n      country: '',\n      status: 'error',\n      total_amt: '',\n      approval_date: '',\n      closing_date: '',\n      implementing_agency: '',\n      sector_primary: '',\n      sectors_all: '',\n      theme_primary: '',\n      themes_all: '',\n      sub_themes: '',\n      project_url: `https://projects.worldbank.org/en/projects-operations/project-detail/${projectId}`,\n      _error: error.message\n    }\n  };\n}"
      },
