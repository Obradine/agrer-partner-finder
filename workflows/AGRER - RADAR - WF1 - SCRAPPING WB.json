    {
      "parameters": {
        "jsCode": "// Collecter les project_ids uniques depuis tous les awards\nconst items = $input.all();\nconst seen = new Set();\nconst unique = [];\n\nfor (const item of items) {\n  const pid = item.json._project_id;\n  if (pid && !seen.has(pid)) {\n    seen.add(pid);\n    unique.push({ json: { project_id: pid } });\n  }\n}\n\nreturn unique;"
      },
      "id": "7fcc78cc-f6c6-48ac-8d3e-1c9bbc91af6e",
      "name": "Collecter Project IDs",
