      "id": "54314d24-4ddb-4b40-8e30-a82eeb314f72",
      "name": "Filtre: a un laurÃĐat",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -656,
        176
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $json;\nconst text = `${item._project_name || ''} ${item._bid_description || ''}`.toLowerCase();\n\nconst tags = [];\n\nif (/agri|agricultur|agro|rural|farm|ÃĐlevage|livestock|semence|seed|irrigation|maraich|pÃŠche|peche|aquacul|halieutique|food|alimentaire|nutrition/.test(text)) tags.push('agro');\nif (/environment|environnement|natural resource|ressource naturelle|forest|forÃŠt|climat|climate|biodiversity|biodiversitÃĐ|waste|dÃĐchet|dechet|eau|water|sanit|assainissement|ÃĐcosystÃĻme|ecosystem|land|foncier|cadastre/.test(text)) tags.push('env');\nif (/energy|ÃĐnergie|solar|solaire|electric|ÃĐlectric|power|renouvelable|renewable|biomass|biomasse|hydropower|photovoltaÃŊque/.test(text)) tags.push('energy');\nif (/infrastructure|construction|travaux|civil works|route|road|pont|bridge|bÃĒtiment|building/.test(text)) tags.push('infra');\nif (/consultant|consulting|ÃĐtude|study|audit|expertise|assistance technique|technical assistance/.test(text)) tags.push('consulting');\n\nconst pgMap = { CS: 'consulting', GO: 'goods', CW: 'civil_works' };\nconst pgTag = pgMap[item._procurement_group] || item._procurement_group;\n\nreturn {\n  json: {\n    ...item,\n    tags: tags.join(',') || 'other',\n    _pg_tag: pgTag\n  }\n};"
      },
      "id": "70854527-1a29-4fa1-8c1a-9e65fc78b450",
      "name": "Tagger",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        176
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const d = item.json;\n  const winnerName = d._winner_names.length > 0 ? d._winner_names[0] : '';\n  const winnerCountry = d._winner_countries.length > 0 ? d._winner_countries[0] : '';\n  const membersComplete = d._consortium_flag\n    ? d._winner_names.map((n, i) => `${n} (${d._winner_countries[i] || '?'})`).join(' | ')\n    : '';\n\n  return {\n    json: {\n      award_id: d.award_id,\n      source: 'World Bank',\n      source_url: d.source_url,\n      place_of_performance: d._country_code,\n      title: d._bid_description || '',\n      publication_date: d._award_date || d._notice_date || '',\n      award_value: d._award_value || '',\n      currency: d._currency || '',\n      tags: d.tags || '',\n      consortium_flag: d._consortium_flag ? 'TRUE' : 'FALSE',\n      members_complete: membersComplete,\n      buyer_name: d._project_name || '',\n      winner_name: winnerName,\n      winner_country: winnerCountry,\n      cpv_category: d._pg_tag || '',\n      procurement_method: d._procurement_method || '',\n      project_id: d._project_id || '',\n      contract_duration: d._contract_duration || '',\n      bid_reference_no: d.bid_reference_no || '',\n      scraped_at: new Date().toISOString()\n    }\n  };\n});"
      },
      "id": "35977883-df02-46be-b659-a6835545da95",
      "name": "PrÃĐparer Rows (Awards)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -192,
        16
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst rows = [];\n\nfor (const item of items) {\n  const d = item.json;\n  d._winner_names.forEach((name, i) => {\n    rows.push({\n      json: {\n        award_id: d.award_id,\n        member_name: name,\n        member_country: d._winner_countries[i] || '',\n        member_rank: i + 1,\n        is_lead: i === 0 ? 'TRUE' : 'FALSE',\n        consortium_flag: d._consortium_flag ? 'TRUE' : 'FALSE',\n        place_of_performance: d._country_code,\n        project_id: d._project_id || '',\n        publication_date: d._award_date || d._notice_date || '',\n        tags: d.tags || '',\n        scraped_at: new Date().toISOString()\n      }\n    });\n  });\n}\n\nreturn rows;"
      },
