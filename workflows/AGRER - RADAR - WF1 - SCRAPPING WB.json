    {
      "parameters": {
        "fieldToSplitOut": "countries",
        "options": {}
      },
      "id": "01f46a63-86cc-44e7-8eee-bec8025a5ab3",
      "name": "Split par Pays",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        -1312,
        176
      ]
    },
    {
      "parameters": {
        "jsCode": "const countries = $input.all().map(i => i.json);\nlet allNotices = [];\n\nfor (const country of countries) {\n  const countryCode = country.code;\n  const countryName = country.name;\n  const pageSize = 50;\n  const baseUrl = 'https://search.worldbank.org/api/v2/procnotices';\n  const startDate = '2022-01-01';\n  \n  let os = 0;\n  let total = null;\n  \n  do {\n    const url = `${baseUrl}?format=json&rows=${pageSize}&os=${os}&notice_type=Contract%20Award&project_ctry_code=${countryCode}&strdate=${startDate}&srt=noticedate&ord=desc`;\n    \n    const data = await this.helpers.httpRequest({ method: 'GET', url, json: true });\n    \n    if (total === null) total = parseInt(data.total || 0);\n    \n    const notices = data.procnotices || [];\n    allNotices = allNotices.concat(notices.map(n => ({ ...n, _country_code: countryCode, _country_name: countryName })));\n    \n    os += pageSize;\n    if (allNotices.length >= 15000) break;\n    \n  } while (os < total);\n  \n  total = null; // reset pour le pays suivant\n}\n\nreturn allNotices.map(n => ({ json: n }));"
      },
      "id": "9e747354-02ca-4a63-9dfb-d3723bd6b358",
      "name": "Paginer API (tous pays)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1088,
        176
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $json;\nconst noticeText = item.notice_text || '';\nlet awardValue = null;\nlet currency = null;\nconst p1 = noticeText.match(/Signed Contract Price<\\/b><br\\/>([A-Z]{2,4})\\s+([\\d,\\.]+)/);\nif (p1) {\n  currency = p1[1];\n  awardValue = parseFloat(p1[2].replace(/,/g, ''));\n}\nif (!currency) {\n  const p2 = noticeText.match(/<div class='col-xs-4'>([A-Z]{3}[^<]*)<\\/div>\\s*<div class='col-xs-4'>([\\d,\\.]+)<\\/div>/);\n  if (p2) {\n    const codeMatch = p2[1].match(/^([A-Z]{3})/);\n    if (codeMatch) currency = codeMatch[1];\n    awardValue = parseFloat(p2[2].replace(/,/g, ''));\n  }\n}\nif (!currency) {\n  const p3 = noticeText.match(/Final Evaluation Price<\\/b><br\\/>([A-Z]{2,4})\\s+([\\d,\\.]+)/);\n  if (p3) {\n    currency = p3[1];\n    awardValue = parseFloat(p3[2].replace(/,/g, ''));\n  }\n}\n\n// Extraire uniquement la section \"Awarded Firm(s)\"\nconst awardedSectionMatch = noticeText.match(\n  /<u>\\s*<b>Awarded Firm\\(s\\):<\\/b><\\/u>([\\s\\S]*?)(?:<u>\\s*<b>(?:Evaluated|Rejected) Firm|$)/\n);\nconst awardedSection = awardedSectionMatch ? awardedSectionMatch[1] : '';\n\nconst winnerNames = [];\nconst winnerCountries = [];\nconst firmRegex = /<b>([^<(]+)\\s*\\(\\d+\\)<\\/b><br\\/>(?:[^<]*<br\\/>)*?Country:\\s*([^<\\n]+)/g;\nlet match;\nwhile ((match = firmRegex.exec(awardedSection)) !== null) {\n  winnerNames.push(match[1].trim());\n  winnerCountries.push(match[2].trim());\n}\n\nlet awardDate = item.noticedate || null;\nconst dateMatch = noticeText.match(/(\\d{4}\\/\\d{2}\\/\\d{2})/);\nif (dateMatch) {\n  awardDate = dateMatch[1].replace(/\\//g, '-');\n}\nlet contractDuration = null;\nconst durMatch = noticeText.match(/Duration of Contract[\\s\\S]{0,30}?(\\d+)\\s*(Month|Year)/i);\nif (durMatch) {\n  contractDuration = `${durMatch[1]} ${durMatch[2]}(s)`;\n}\nconst consortiumFlag = winnerNames.length > 1;\nreturn {\n  json: {\n    _raw_id: item.id,\n    _country_code: item._country_code,\n    _country_name: item._country_name,\n    _notice_date: item.noticedate,\n    _project_name: item.project_name,\n    _project_id: item.project_id,\n    _bid_description: item.bid_description,\n    _procurement_group: item.procurement_group,\n    _procurement_method: item.procurement_method_name || null,\n    _winner_names: winnerNames,\n    _winner_countries: winnerCountries,\n    _award_value: awardValue,\n    _currency: currency,\n    _award_date: awardDate,\n    _contract_duration: contractDuration,\n    _consortium_flag: consortiumFlag,\n    award_id: `WB_${item._country_code}_${item.id}`,\n    source_url: `https://projects.worldbank.org/en/projects-operations/procurement-detail/${item.id}`,\n    bid_reference_no: item.bid_reference_no || ''\n  }\n};"
      },
      "id": "fae7d07b-1a67-4f37-986f-6613cad61ea5",
      "name": "Parser notice_text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -864,
        176
      ]
    },
